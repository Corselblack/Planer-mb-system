# GOOGLE_APPLICATION_CREDENTIALS=./google-sa-key.json

# ElevenLabs (complementar)
ELEVENLABS_API_KEY=sua-api-key-elevenlabs

# YouTube Data API v3
YOUTUBE_API_KEY=sua-api-key-youtube
